# Optional live SDK credentials.
# Copy this file to `.env` for local experiments. Never commit `.env`.

OPENAI_API_KEY=
GEMINI_API_KEY=

# Google ADK commonly reads GOOGLE_API_KEY. The showcase copies GEMINI_API_KEY
# into GOOGLE_API_KEY at runtime when GOOGLE_API_KEY is not already set.
# Set GOOGLE_API_KEY directly if your local ADK setup prefers that name.
GOOGLE_API_KEY=

# Current low-cost defaults as of 2026-05-09.
# OpenAI: cheapest listed GPT-5.4-class model in official API pricing.
# Gemini: cheapest listed Gemini 3.1 agentic text model in official Gemini pricing.
OPENAI_MODEL=gpt-5.4-mini
GEMINI_MODEL=gemini-3.1-flash-lite-preview
